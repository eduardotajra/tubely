PORT=3334
DATABASE_URL=postgresql://docker:docker@localhost:5433/tubely

# Cloudflare R2 (S3-compatible)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKET=tubely
CLOUDFLARE_PUBLIC_URL=

# Storage mode: 'r2' or 'local' (use 'local' for development without R2)
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./uploads
